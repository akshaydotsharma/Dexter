# Copy this file to `client/.env` if you need to override defaults. The .env
# file is gitignored. Most local-dev users do not need a .env at all because
# Vite proxies /api to the local server (see client/vite.config.js).

# Override the API base URL for production builds where the client and the
# server are served from different origins. Leave unset for local dev.
# VITE_API_URL=https://api.your-deployment.example.com
