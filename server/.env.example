# Copy this file to `server/.env` and fill in your own values. The .env file
# is gitignored so your secrets never get committed.

# Port the Express API listens on. The iOS app's AppConfig.swift defaults to
# http://localhost:3000/api, so keep this at 3000 unless you also override
# the iOS API_URL.
PORT=3000

# Connection string for the PostgreSQL database the app reads/writes.
# Example: postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgres://user:password@localhost:5432/personal_dashboard

# Anthropic API key, required for the AI chat / draft features.
# Get one at https://console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=sk-ant-replace-with-your-own-key

# Where the web client is served from in production (used for CORS).
# Leave unset for local development.
# FRONTEND_URL=https://your-frontend.example.com

# Optional: only used by legacy/diagnostic scripts (server/test-bytez.js,
# server/check-env.js). The active chat path uses ANTHROPIC_API_KEY above.
# OPENAI_API_KEY=sk-replace-or-leave-unset
